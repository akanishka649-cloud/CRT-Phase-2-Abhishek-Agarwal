//Reverse a linkedlist
class Solution {
public:
    ListNode* reverseList(ListNode* head) {
        ListNode* prev=nullptr;
        ListNode* curr=head;
        ListNode* agla=nullptr;
        while(curr!= nullptr){
            agla=curr->next;
            curr->next=prev;
            prev=curr;
            curr=agla;
        }


     return prev;
    }
};
