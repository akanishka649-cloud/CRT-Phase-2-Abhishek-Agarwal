//Program 1
//LEETCODE 876
//find middle of the linkedlist
class Solution {
public:
    ListNode* middleNode(ListNode* head) {
       ListNode* slow=head;
        ListNode* fast=head;
        while(fast!=nullptr &&fast->next!=nullptr){
            slow=slow->next;
            fast=fast->next->next;
        }
        return slow;
        
    }
};







//Program 2
//LEETCODE 141
//LINKEDLIST CYCLE
class Solution {
public:
    bool hasCycle(ListNode *head) {
        ListNode *slow=head;
        ListNode *fast=head;
        while(fast!=nullptr && fast->next!=nullptr){
            slow=slow->next;
            fast=fast->next->next;
            if(slow==fast){
                return true;
            }
        }
        return false;
    }
};










